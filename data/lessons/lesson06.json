        ]},
        { "lines": [
          { "filipino": "Mayroon akong oras sa Lunes.", "english": "I have time on Monday.", "chinese": "我星期一有時間", "pinyin": "Wǒ xīng qí yī yǒu shí jiān." }
        ]},
        { "lines": [
          { "filipino": "Maraming ginagawa ang boss ko sa linggo ng hapon.", "english": "My boss is busy on Sunday afternoon.", "chinese": "我的老闆星期天下午很忙", "pinyin": "Wǒ de lǎo bǎn xīng qí tiān xià wǔ hěn máng." }
