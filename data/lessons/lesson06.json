        { "lines": [
          { "filipino": "Anong araw ngayon?", "english": "What day is it today?", "chinese": "今天是星期幾？", "pinyin": "Jīn tiān shì xīng qí jǐ?" },
          { "filipino": "Ngayon ay Miyerkules.", "english": "Today is Wednesday.", "chinese": "今天是星期三", "pinyin": "Jīn tiān shì xīng qí sān." }
        ]},
        { "lines": [
          { "filipino": "Alas otso ng umaga.", "english": "Eight o'clock in the morning.", "chinese": "早上八點", "pinyin": "Zǎo shàng bā diǎn." }
