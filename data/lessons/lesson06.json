        { "lines": [
          { "filipino": "Ikatlong linggo nitong buwan.", "english": "Third week of this month.", "chinese": "這個月第三個星期", "pinyin": "Zhè gè yuè dì sān gè xīng qí." }
        ]},
        { "lines": [
          { "filipino": "Disyembre ng nakaraang taon.", "english": "December of Last year.", "chinese": "去年十二月", "pinyin": "Qù nián shí èr yuè." }
        ]},
        { "lines": [
          { "filipino": "Ika-25 ng Oktubre, 2007.", "english": "October 25, 2007.", "chinese": "二零零七年十月二十五日", "pinyin": "èr líng líng qī nián shí yuè èr shí wǔ rì / liǎng qiān líng qī nián shí yuè èr shí wǔ rì" },
