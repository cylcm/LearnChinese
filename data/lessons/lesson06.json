        { "lines": [
          { "filipino": "Magluluto ako ng alas-sais ng hapon.", "english": "I will cook at 6 p.m.", "chinese": "我下午六點要煮飯", "pinyin": "Wǒ xià wǔ liù diǎn yào zhǔ fàn." }
