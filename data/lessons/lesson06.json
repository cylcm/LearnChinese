      "type": "dialogue",
      "dialogues": [
        { "lines": [
          { "filipino": "Anong oras na ngayon?", "english": "What time is it now?", "chinese": "現在幾點？", "pinyin": "Xiàn zài jǐ diǎn?" },
          { "filipino": "Ngayon ay alas tres ng hapon.", "english": "Now is three o'clock in the afternoon.", "chinese": "現在是下午三點", "pinyin": "Xiàn zài shì xià wǔ sān diǎn." }
