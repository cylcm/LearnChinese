        { "lines": [
          { "filipino": "Anong petsa ngayon?", "english": "What is the date today?", "chinese": "今天是幾月幾號？", "pinyin": "Jīn tiān shì jǐ yuè jǐ hào?" },
          { "filipino": "Ngayon ay ika-12 ng Setyembre.", "english": "Today is September 12.", "chinese": "今天是九月十二號", "pinyin": "Jīn tiān shì jiǔ yuè shí èr hào." }
