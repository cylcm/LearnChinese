    {
      "heading": "3. Conversations",
      "type": "dialogue",
      "dialogues": [
        { "lines": [ { "filipino": "Ako ay natutulog sa kuwarto.", "english": "I am sleeping in the room.", "chinese": "我在房間睡覺", "pinyin": "Wǒ zài fáng jiān shuì jiào." } ]},
        { "lines": [ { "filipino": "Siya ay naglalaro sa parke.", "english": "He is playing in the park.", "chinese": "他在公園玩", "pinyin": "Tā zài gōng yuán wán." } ]},
        { "lines": [ { "filipino": "Kami ay pumunta sa department store para bumili ng gamit.", "english": "We went to department store to buy things.", "chinese": "我們去百貨公司買東西", "pinyin": "Wǒ mén qù bǎi huò gōng sī mǎi dōng xī." } ]},
        { "lines": [ { "filipino": "Ang aking amo ay kumain sa restauran.", "english": "My boss ate at the restaurant.", "chinese": "我的老闆到餐館吃飯", "pinyin": "Wǒ de lǎo bǎn dào cān guǎn chī fàn." } ]},
        { "lines": [ { "filipino": "Ang katulong ay naglalaba sa bahay.", "english": "The maid is washing the clothes at home.", "chinese": "傭人在家裡洗衣服", "pinyin": "Yōng rén zài jiā lǐ xǐ yī fú." } ]},
        { "lines": [ { "filipino": "Ang estudyante ay nag-aaral sa paaralan.", "english": "The student is studying in the school.", "chinese": "學生在學校讀書", "pinyin": "Xué shēng zài xué xiào dú shū." } ]},
        { "lines": [ { "filipino": "Ang guro ay naghihintay ng sasakyan sa istasyon ng bus.", "english": "The teacher is waiting for a ride at the bus station.", "chinese": "老師在公車站等車", "pinyin": "Lǎo shī zài gōng chē zhàn děng chē." } ]},
        { "lines": [ { "filipino": "Ang trabahador ay pumunta sa bangko para magpadala ng pera.", "english": "The worker went to the bank to send money.", "chinese": "工人去銀行寄錢", "pinyin": "Gōng rén qù yín háng jì qián." } ]},
        { "lines": [ { "filipino": "Lumiko sa kanan papunta sa palengke.", "english": "Turn right to the market.", "chinese": "右轉去菜市場", "pinyin": "Yòu zhuǎn qù cài shì cháng." } ]},
        { "lines": [ { "filipino": "Si lola ay ayaw pumunta sa ospital para magpatingin sa doktor.", "english": "Grandmother doesn't want to go to the hospital to consult the doctor.", "chinese": "阿嬤不要去醫院看醫生", "pinyin": "A má bú yào qù yī yuàn kàn yī shēng." } ]},
        { "lines": [ { "filipino": "Mula alas otso hanggang alas nueve ng umaga, siya ay naglilinis ng sala.", "english": "From eight to nine o'clock in the morning, she was cleaning the living room.", "chinese": "從早上八點到九點，他在打掃客廳", "pinyin": "Cóng zǎo shàng bā diǎn dào jiǔ diǎn, tā zài dǎ sǎo kè tīng." } ]}
      ]
