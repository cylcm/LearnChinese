    {
      "heading": "2. Conversations",
      "type": "dialogue",
      "dialogues": [
        { "lines": [ { "filipino": "Masama ang pakiramdam ko.", "english": "I am not feeling well.", "chinese": "我不舒服。", "pinyin": "Wǒ bù shū fú." } ] },
        { "lines": [ { "filipino": "May sakit po ako.", "english": "I am sick.", "chinese": "我生病了。", "pinyin": "Wǒ shēng bìng le." } ] },
        { "lines": [ { "filipino": "Saan ang masakit?", "english": "Where does it hurt?", "chinese": "哪裡痛?", "pinyin": "Nǎ lǐ tòng?" } ] },
        { "lines": [ { "filipino": "Mas maginhawa ba?", "english": "Is this more comfortable?", "chinese": "這樣舒服嗎?", "pinyin": "Zhè yàng shū fú ma?" } ] },
        { "lines": [ { "filipino": "Ituwid ang kama.", "english": "Level the bed.", "chinese": "床搖平。", "pinyin": "Chuáng yáo píng." } ] },
        { "lines": [ { "filipino": "Itaas ang kama.", "english": "Raise the bed.", "chinese": "床搖高一點。", "pinyin": "Chuáng yáo gāo yì diǎn." } ] },
        { "lines": [ { "filipino": "Ibaba ang kama.", "english": "Lower the bed.", "chinese": "床搖低一點。", "pinyin": "Chuáng yáo dī yì diǎn." } ] },
        { "lines": [ { "filipino": "Buksan ang kurtina.", "english": "Open the curtain.", "chinese": "拉開窗簾。", "pinyin": "Lā kāi chuāng lián." } ] },
        { "lines": [ { "filipino": "Isara ang kurtina.", "english": "Close the curtain.", "chinese": "拉上窗簾。", "pinyin": "Lā shàng chuāng lián." } ] },
        { "lines": [ { "filipino": "Gusto mo bang bumaba sa kama, maglakad at gumalaw?", "english": "Do you want to get down from the bed and walk around?", "chinese": "要不要下床走動?", "pinyin": "Yào bú yào xià chuáng zǒu dòng?" } ] },
        { "lines": [ { "filipino": "Malamig ba?", "english": "Is it cold?", "chinese": "會冷嗎?", "pinyin": "Huì lěng ma?" } ] },
        { "lines": [ { "filipino": "Mainit ba?", "english": "Is it hot?", "chinese": "會熱嗎?", "pinyin": "Huì rè ma?" } ] },
        { "lines": [ { "filipino": "Palitan ang damit.", "english": "Change clothes.", "chinese": "換衣服。", "pinyin": "Huàn yī fú." } ] },
        { "lines": [ { "filipino": "Palitan ang kubre-kama.", "english": "Change bed-sheet.", "chinese": "換床單。", "pinyin": "Huàn chuáng dān." } ] },
        { "lines": [ { "filipino": "Tingnan ang diaper kung basa.", "english": "Check the diaper if it is wet.", "chinese": "檢查尿布有沒有濕。", "pinyin": "Jiǎn chá niào bù yǒu méi yǒu shī." } ] },
        { "lines": [ { "filipino": "May kabag ka ba?", "english": "Do you have gas pain?", "chinese": "你肚子脹不脹?", "pinyin": "Nǐ dù zi zhàng bú zhàng?" } ] },
        { "lines": [ { "filipino": "Masakit ba ang tiyan mo?", "english": "Does your stomach ache?", "chinese": "你肚子痛嗎?", "pinyin": "Nǐ dù zi tòng ma?" } ] },
        { "lines": [ { "filipino": "Gusto mo bang umihi?", "english": "Do you want to pee?", "chinese": "你要小便嗎?", "pinyin": "Nǐ yào xiǎo biàn ma?" } ] },
        { "lines": [ { "filipino": "Gusto mo bang dumumi?", "english": "Do you want to go to the restroom?", "chinese": "你要大便嗎?", "pinyin": "Nǐ yào dà biàn ma?" } ] },
        { "lines": [ { "filipino": "Hindi ka ba nakakadumi?", "english": "Are you constipated?", "chinese": "你便秘嗎?", "pinyin": "Nǐ biàn mì ma?" } ] },
        { "lines": [ { "filipino": "Sige po, sasabihin ko sa nars.", "english": "Okay, I'll tell the nurse.", "chinese": "好的,我會告訴護士。", "pinyin": "Hǎo de, wǒ huì gào sù hù shì." } ] }
      ]
    }
  ]
