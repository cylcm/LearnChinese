        { "lines": [
          { "filipino": "Gusto ko ng mas maraming prutas.", "english": "I want more fruits.", "chinese": "我要多一點水果。", "pinyin": "Wǒ yào duō yī diǎn shuǐ guǒ." }
        ]},
        { "lines": [
          { "filipino": "Masyadong malakas ang boses mo.", "english": "Your voice is too loud.", "chinese": "你的聲音太大聲。", "pinyin": "Nǐ de shēng yīn tài dà shēng." }
