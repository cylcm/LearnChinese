        { "lines": [
          { "filipino": "Iyong estudyante ay masyadong mataba.", "english": "That student is too fat.", "chinese": "那個學生太胖。", "pinyin": "Nà gè xué shēng tài pàng." }
        ]},
        { "lines": [
          { "filipino": "Ikaw ang pinakamaganda sa inyong tatlo.", "english": "You are the most beautiful among the three.", "chinese": "你們三個你最漂亮。", "pinyin": "Nǐ mén sān gè nǐ zuì piào liàng." }
        ]},
        { "lines": [
          { "filipino": "Ang aming bahay ay mas malaki ngayon.", "english": "Our house is bigger now.", "chinese": "我們現在的房子比較大。", "pinyin": "Wǒ mén xiàn zài de fáng zi bǐ jiào dà." }
