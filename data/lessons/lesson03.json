    {
      "heading": "7. Conversations",
      "type": "dialogue",
      "dialogues": [
        {
          "lines": [
            { "filipino": "Ginoong Wang, magandang umaga, kumusta po kayo?", "english": "Mr. Wang, good morning. How are you?", "chinese": "王先生，早安，你好嗎？", "pinyin": "Wáng xiān shēng, zǎo ān. Nǐ hǎo ma?" },
            { "filipino": "Binibining Zhang, mabuti ako, salamat po.", "english": "Miss Zhang, I'm fine. Thanks.", "chinese": "張小姐，我很好，謝謝", "pinyin": "Zhāng xiǎo jiě, Wǒ hěn hǎo, xiè xiè." }
          ]
        },
        {
          "lines": [
            { "filipino": "Salamat sa iyo.", "english": "Thank you.", "chinese": "謝謝你", "pinyin": "Xiè xiè nǐ." },
            { "filipino": "Walang anuman.", "english": "You are welcome.", "chinese": "不客氣 / 不用謝", "pinyin": "Bú kè qì / Bú yòng xiè" }
          ]
        },
        {
          "lines": [
            { "filipino": "Ano po ang apelyido at pangalan niyo?", "english": "What's your surname and first name?", "chinese": "您貴姓大名？", "pinyin": "Nín guì xìng dà míng?" },
            { "filipino": "Ang apelyido ko ay ___, ang pangalan ko ay ___.", "english": "My surname is ___, my name is ___.", "chinese": "我姓 ___，我叫 ___", "pinyin": "Wǒ xìng ___, Wǒ jiào ___." }
          ]
        },
        {
          "lines": [
            { "filipino": "Ikaw ay mula sa anong bansa?", "english": "You are from what country?", "chinese": "你是那國人？", "pinyin": "Nǐ shì nǎ guó rén?" },
            { "filipino": "Ako ay Filipino.", "english": "I am Filipino.", "chinese": "我是菲律賓人", "pinyin": "Wǒ shì Fēi Lǜ Bīn rén" }
          ]
        },
        {
          "lines": [
            { "filipino": "Siya ba ay Filipino?", "english": "Is she Filipino?", "chinese": "他是菲律賓人嗎？", "pinyin": "Tā shì Fēi Lǜ Bīn rén ma?" },
            { "filipino": "Siya ay hindi Filipino. Siya ay Tsino.", "english": "She is not Filipino. She is Chinese.", "chinese": "他不是菲律賓人. 他是中國人", "pinyin": "Tā bú shì Fēi Lǜ Bīn rén. Tā shì Zhōng Guó rén." }
          ]
        },
        {
          "lines": [
            { "filipino": "Sila ay mula sa anong bansa?", "english": "They are from what country?", "chinese": "他們是那國人？", "pinyin": "Tā mén shì nǎ guó rén?" },
            { "filipino": "Sila ay Filipino.", "english": "They are Filipinos.", "chinese": "他們是菲律賓人", "pinyin": "Tā mén shì Fēi Lǜ Bīn rén." }
          ]
        },
        {
          "lines": [
            { "filipino": "Sino Siya?", "english": "Who is he?", "chinese": "他是誰？", "pinyin": "Tā shì shéi?" },
            { "filipino": "Siya ay hindi amo. Siya ay trabahador.", "english": "He is not the boss. He is the worker.", "chinese": "他不是老闆. 他是工人", "pinyin": "Tā bú shì lǎo bǎn. Tā shì gōng rén." }
          ]
        },
        {
          "lines": [
            { "filipino": "Ano ito?", "english": "What is this?", "chinese": "這是什麼？", "pinyin": "Zhè shì shé me?" },
            { "filipino": "Ito ay panulat.", "english": "This is pen.", "chinese": "這是筆", "pinyin": "Zhè shì bǐ." }
          ]
        },
        {
          "lines": [
            { "filipino": "Ano iyon?", "english": "What is that?", "chinese": "那是什麼？", "pinyin": "Nà shì shé me?" },
            { "filipino": "Iyon ay aklat.", "english": "That is a book.", "chinese": "那是書", "pinyin": "Nà shì shū." }
          ]
        },
        {
          "lines": [
            { "filipino": "Anong aklat iyon?", "english": "What book is that?", "chinese": "那是什麼書？", "pinyin": "Nà shì shé me shū?" },
            { "filipino": "Iyon ay aklat na Ingles.", "english": "That is an English book.", "chinese": "那是英文書", "pinyin": "Nà shì Yīng wén shū." }
          ]
        },
        {
          "lines": [
            { "filipino": "Iyon ba ay aklat na Ingles din?", "english": "Is that also an English book?", "chinese": "那也是英文書嗎？", "pinyin": "Nà yě shì Yīng wén shū ma?" },
            { "filipino": "Iyon ay hindi aklat na Ingles. Iyon ay aklat na Tsino.", "english": "That is not an English book. That is a Chinese book.", "chinese": "那不是英文書. 那是中文書", "pinyin": "Nà bú shì Yīng wén shū. Nà shì Zhōng wén shū." }
          ]
        },
        {
          "lines": [
            { "filipino": "Kanino ang panulat na ito?", "english": "Whose pen is this?", "chinese": "這是誰的筆？", "pinyin": "Zhè shì shéi de bǐ?" },
            { "filipino": "Ito ay akin.", "english": "This is mine.", "chinese": "這是我的", "pinyin": "Zhè shì wǒ de." }
          ]
        },
        {
          "lines": [
            { "filipino": "Ang mga damit na iyon ay sa iyo ba?", "english": "Are those clothes yours?", "chinese": "那些是你的衣服嗎？", "pinyin": "Nà xiē shì nǐ de yī fú ma?" },
            { "filipino": "Hindi, ang mga iyon ay hindi akin. Ang mga iyon ay kay Ginoong Wang.", "english": "No, those are not mine. Those are Mr. Wang's.", "chinese": "不，那些不是我的. 那些是王先生的", "pinyin": "Bù, Nà xiē bú shì wǒ de. Nà xiē shì Wáng xiān shēng de." }
          ]
        },
        {
          "lines": [
            { "filipino": "Masaya ako nakita kita.", "english": "I am glad to meet you.", "chinese": "見到你我很高興", "pinyin": "Jiàn dào nǐ wǒ hěn gāo xìng." }
          ]
        }
      ]
    }
  ]
