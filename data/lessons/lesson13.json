    {
      "heading": "4. Conversations",
      "type": "dialogue",
      "dialogues": [
        { "lines": [ { "filipino": "Paki-hintay ng saglit.", "english": "Please wait for a while.", "chinese": "請等一下。", "pinyin": "Qǐng děng yí xià." } ] },
        { "lines": [ { "filipino": "Saan ka pupunta?", "english": "Where are you going?", "chinese": "你要到那裡?", "pinyin": "Nǐ yào dào nǎ lǐ?" } ] },
        { "lines": [ { "filipino": "Pumunta sa palengke.", "english": "Go to market.", "chinese": "到菜市場。", "pinyin": "Dào cài shì cháng." } ] },
        { "lines": [ { "filipino": "Pumunta sa pamilihan.", "english": "Go to supermarket.", "chinese": "到超級市場。", "pinyin": "Dào chāo jí shì cháng." } ] },
        { "lines": [ { "filipino": "Pumunta sa tindahan.", "english": "Go to grocery store.", "chinese": "到雜貨店。", "pinyin": "Dào zá huò diàn." } ] },
        { "lines": [ { "filipino": "Pumunta sa botika.", "english": "Go to drug store.", "chinese": "到藥房。", "pinyin": "Dào yào fáng." } ] },
        { "lines": [ { "filipino": "Anong bibilhin?", "english": "Buy what?", "chinese": "買什麼?", "pinyin": "Mǎi shé me?" } ] },
        { "lines": [ { "filipino": "Kunin ang resibo.", "english": "Get a receipt.", "chinese": "拿發票回來。", "pinyin": "Ná fā piào huí lái." } ] },
        { "lines": [ { "filipino": "Saan po ang daan?", "english": "How to get there?", "chinese": "請問怎麼走?", "pinyin": "Qǐng wèn zěn me zǒu?" } ] },
        { "lines": [ { "filipino": "Mayroon kayong ___?", "english": "Do you have ___?", "chinese": "你們有 ___ 嗎?", "pinyin": "Nǐ mén yǒu ___ ma?" } ] },
        { "lines": [ { "filipino": "May pera ka ba?", "english": "Do you have money?", "chinese": "你有錢嗎?", "pinyin": "Nǐ yǒu qián ma?" } ] },
        { "lines": [ { "filipino": "Magkano gusto mo?", "english": "How much do you want?", "chinese": "你要多少錢?", "pinyin": "Nǐ yào duō shǎo qián?" } ] },
        { "lines": [ { "filipino": "Gusto ko ng NT$150.", "english": "I want NT$150.", "chinese": "我要 NT$150。", "pinyin": "Wǒ yào yī bǎi wǔ shí kuài." } ] },
        { "lines": [ { "filipino": "Magkano lahat?", "english": "How much in all?", "chinese": "一共多少錢?", "pinyin": "Yí gòng duō shǎo qián?" } ] },
        { "lines": [ { "filipino": "Gusto mo bang makita?", "english": "Would you like to see it?", "chinese": "你要不要看?", "pinyin": "Nǐ yào bú yào kàn?" } ] },
        { "lines": [ { "filipino": "Gusto ko itong damit.", "english": "I like this cloth.", "chinese": "我喜歡這件衣服。", "pinyin": "Wǒ xǐ huān zhè jiàn yī fú." } ] },
        { "lines": [ { "filipino": "Magkano po ito?", "english": "How much is this?", "chinese": "這個多少錢?", "pinyin": "Zhè gè duō shǎo qián?" } ] },
        { "lines": [ { "filipino": "Gusto ko ng ___.", "english": "I want ___.", "chinese": "我要 ___。", "pinyin": "Wǒ yào ___." } ] },
        { "lines": [ { "filipino": "Puwede mo bang ibaba ang presyo?", "english": "Can you lower the price?", "chinese": "可以便宜一點嗎?", "pinyin": "Kě yǐ pián yí yì diǎn ma?" } ] },
        { "lines": [ { "filipino": "Gusto ko ito.", "english": "I like this.", "chinese": "我喜歡這個。", "pinyin": "Wǒ xǐ huān zhè gè." } ] },
        { "lines": [ { "filipino": "Ayaw ko iyon.", "english": "I don't like that.", "chinese": "我不喜歡那個。", "pinyin": "Wǒ bù xǐ huān nà gè." } ] }
      ]
    }
