    {
      "heading": "Conversations",
      "type": "dialogue",
      "dialogues": [
        { "lines": [ { "filipino": "Ako ay naglalaba.", "english": "I am washing the clothes.", "chinese": "我在洗衣服", "pinyin": "Wǒ zài xǐ yī fú." } ]},
        { "lines": [ { "filipino": "Ang kanilang guro ay naghihilamos.", "english": "Their teacher is washing her face.", "chinese": "他們的老師在洗臉", "pinyin": "Tā mén de lǎo shī zài xǐ liǎn." } ]},
        { "lines": [ { "filipino": "Sila ay gustong kumanta.", "english": "They want to sing.", "chinese": "他們想要唱歌", "pinyin": "Tā mén xiǎng yào chàng gē." } ]},
        { "lines": [ { "filipino": "Ang aking amo ay naligo na.", "english": "My boss had taken a bath.", "chinese": "我的老闆已經洗澡了", "pinyin": "Wǒ de lǎo bǎn yǐ jīng xǐ zǎo le." } ]},
        { "lines": [ { "filipino": "Ang trabahador ay hindi naglampaso ng sahig.", "english": "The worker did not mop the floor.", "chinese": "工人沒有拖地板", "pinyin": "Gōng rén méi yǒu tuō dì bǎn." } ]},
        { "lines": [ { "filipino": "Ang pasyente ay hindi pa nagbabayad.", "english": "The patient did not pay the bill yet.", "chinese": "病人還沒有付錢", "pinyin": "Bìng rén hái méi yǒu fù qián." } ]},
        { "lines": [ { "filipino": "Ang bata ay hindi puwedeng maglaro.", "english": "The child cannot play.", "chinese": "小孩不可以玩", "pinyin": "Xiǎo hái bù kě yǐ wán." } ]},
        { "lines": [ { "filipino": "Ang pulis na iyon ay hindi marunong magluto.", "english": "That policeman doesn't know how to cook.", "chinese": "那個警察不會煮飯", "pinyin": "Nà gè jǐng chá bú huì zhǔ fàn." } ]},
        { "lines": [ { "filipino": "Sabi ng amo puwede na kaming kumain ng merienda.", "english": "Boss said we can eat snack.", "chinese": "老闆說我們可以吃點心", "pinyin": "Lǎo bǎn shuō wǒ mén kě yǐ chī diǎn xīn." } ]},
        { "lines": [ { "filipino": "Madalas kaming nagkukuwentuhan.", "english": "We often chat.", "chinese": "我們常常聊天", "pinyin": "Wǒ mén cháng cháng liáo tiān." } ]},
        { "lines": [ { "filipino": "Dahil umuulan, kaya hindi na ako lalabas.", "english": "Because it is raining, that's why I will not go out.", "chinese": "因為在下雨，所以我不出去了", "pinyin": "Yīn wèi zài xià yǔ, suǒ yǐ wǒ bù chū qù le." } ]}
      ]
    }
  ]
