    {
      "heading": "9. Conversations",
      "type": "dialogue",
      "dialogues": [
        { "lines": [ { "filipino": "Oras na para magluto.", "english": "It's time to cook.", "chinese": "該煮飯了。", "pinyin": "Gāi zhǔ fàn le." } ] },
        { "lines": [ { "filipino": "Marunong ka bang magluto?", "english": "Do you know how to cook?", "chinese": "你會做飯嗎?", "pinyin": "Nǐ huì zuò fàn ma?" } ] },
        { "lines": [ { "filipino": "Ano po ang gusto nilang kainin?", "english": "What do you want to eat?", "chinese": "您要吃什麼?", "pinyin": "Nín yào chī shé me?" } ] },
        { "lines": [ { "filipino": "Paano po iluto?", "english": "How do you cook this dish?", "chinese": "這菜怎麼煮?", "pinyin": "Zhè cài zěn me zhǔ?" } ] },
        { "lines": [ { "filipino": "Salamat sa pag-imbita mo sa akin sa iyong tahanan.", "english": "Thank you for inviting me to your house.", "chinese": "謝謝你請我來你家。", "pinyin": "Xiè xiè nǐ qǐng wǒ lái nǐ jiā." } ] },
        { "lines": [ { "filipino": "Ang sarap talaga ng lutong bahay.", "english": "It's a treat to have a homecooked meal.", "chinese": "能吃家庭菜真好。", "pinyin": "Néng chī jiā tíng cài zhēn hǎo." } ] },
        { "lines": [ { "filipino": "Napakagaling mong magluto.", "english": "You are an excellent cook.", "chinese": "你很會做菜。", "pinyin": "Nǐ hěn huì zuò cài." } ] },
        { "lines": [ { "filipino": "Masarap ang luto mo.", "english": "You cook well.", "chinese": "你煮的菜很好吃。", "pinyin": "Nǐ zhǔ de cài hěn hǎo chī." } ] },
        { "lines": [ { "filipino": "Anong oras po kakain?", "english": "What time will you eat?", "chinese": "幾點吃飯?", "pinyin": "Jǐ diǎn chī fàn?" } ] },
        { "lines": [ { "filipino": "Kailangan mo ba ng tubig?", "english": "Do you need some water?", "chinese": "您要喝水嗎?", "pinyin": "Nín yào hē shuǐ ma?" } ] },
        { "lines": [ { "filipino": "Mag-enjoy po kayo sa inyong pagkain.", "english": "Enjoy your meal.", "chinese": "慢慢用。", "pinyin": "Màn màn yòng." } ] },
        { "lines": [ { "filipino": "Tama po ba sa panlasa niyo?", "english": "How do you like the dishes?", "chinese": "菜合胃口嗎?", "pinyin": "Cài hé wèi kǒu ma?" } ] },
        { "lines": [ { "filipino": "Gusto po ninyo magmerienda?", "english": "Do you want some snacks?", "chinese": "您要吃點心嗎?", "pinyin": "Nín yào chī diǎn xīn ma?" } ] }
      ]
    }
